{
  "name": "config-master",
  "version": "0.0.0",
  "scripts": {
    "ng": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx ng\"",
    "start": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx ng serve\"",
    "start:dev": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx ng serve --configuration development\"",
    "start:prod": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx ng serve --configuration production\"",
    "build": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx ng build\"",
    "build:dev": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx ng build --configuration development\"",
    "build:prod": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx ng build --configuration production\"",
    "watch": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx ng build --watch --configuration development\"",
    "test": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx ng test\"",
    "serve:ssr:ConfigMaster": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && node dist/config-master/server/server.mjs\"",
    "compodoc:build": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx compodoc -p tsconfig.json -d docs --theme vagrant\"",
    "compodoc:serve": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx compodoc -s -d docs --theme vagrant\"",
    "e2e": "npx --yes -c \"cd Frontend\\ConfigMasterHPS-main && npx ng e2e\"",
    "backend:run": "mvn -f SIT/ConfigMaster-Backend/pom.xml spring-boot:run",
    "backend:spring-boot-run": "mvn -f SIT/ConfigMaster-Backend/pom.xml spring-boot:run",
    "backend:clean": "mvn -f SIT/ConfigMaster-Backend/pom.xml clean",
    "backend:build": "mvn -f SIT/ConfigMaster-Backend/pom.xml clean package",
    "backend:test": "mvn -f SIT/ConfigMaster-Backend/pom.xml test"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^19.2.3",
    "@angular/common": "^19.2.2",
    "@angular/compiler": "^19.2.2",
    "@angular/core": "^19.2.2",
    "@angular/forms": "^19.2.2",
    "@angular/material": "^19.2.3",
    "@angular/platform-browser": "^19.2.2",
    "@angular/platform-browser-dynamic": "^19.2.2",
    "@angular/platform-server": "^19.2.2",
    "@angular/router": "^19.2.2",
    "@angular/ssr": "^19.2.3",
    "@auth0/angular-jwt": "^5.2.0",
    "@ng-bootstrap/ng-bootstrap": "^18.0.0",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "chart.js": "^3.9.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "express": "^4.18.2",
    "ng2-charts": "^8.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "vis-network": "^9.1.10",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.3",
    "@angular/cli": "^19.2.3",
    "@angular/compiler-cli": "^19.2.2",
    "@angular/localize": "^19.2.2",
    "@compodoc/compodoc": "^1.1.26",
    "@playwright/test": "1.58.2",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.7",
    "@types/node": "^22.13.10",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "playwright-ng-schematics": "^2.0.3",
    "typescript": "~5.8.2"
  }
}